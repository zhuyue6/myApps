
/** 全局治愈风：马卡龙浅色系、柔和圆角 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #333333;
  background: #f6f8fb;
  box-sizing: border-box;
  --button-primary-background-color: #7ec8e3;
  --button-primary-border-color: #7ec8e3;
  --tabs-default-color: #5a8fc7;
}

