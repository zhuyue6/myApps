.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.head-card {
  background: linear-gradient(135deg, #f6fbff 0%, #eaf4fc 100%);
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
}

.head-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.type-badge {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  color: #ffffff;
  flex-shrink: 0;
}

.type-main {
  background: #7ec8e3;
}

.type-sub {
  background: #b9d5e7;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status {
  font-size: 24rpx;
  color: #888888;
  flex-shrink: 0;
}

.status-in_progress {
  color: #5a8fc7;
}

.status-completed {
  color: #5cb67f;
}

.status-incomplete {
  color: #d98e8e;
}

.status-paused {
  color: #a98d5b;
}

.meta-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #8a99ad;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.meta-tag {
  color: #5a8fc7;
}

.prog-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.prog-row .van-progress {
  flex: 1;
}

.prog-text {
  font-size: 26rpx;
  color: #5a8fc7;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

.rule-hint {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #6a8eb0;
  padding: 10rpx 16rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  line-height: 1.5;
}

.action-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.primary-btn {
  font-weight: 600 !important;
}

.tip {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #a0a7b0;
}

.makeup-wrap {
  margin-top: 18rpx;
  display: flex;
  justify-content: center;
}

.section-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.section-sub {
  font-size: 22rpx;
  color: #a0a7b0;
}

.section-action {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  color: #5a8fc7;
  font-size: 24rpx;
  padding: 4rpx 10rpx;
}

.sub-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f5f9;
}

.sub-row:last-child {
  border-bottom: none;
}

.sub-name {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.sub-right {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.sub-weight {
  font-size: 24rpx;
  color: #5a8fc7;
}

.empty-line {
  padding: 16rpx 0;
  color: #a0a7b0;
  font-size: 24rpx;
}

.desc-text {
  display: block;
  font-size: 26rpx;
  color: #555555;
  line-height: 1.6;
}

.ck-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f3f5f9;
}

.ck-row:last-child {
  border-bottom: none;
}

.ck-label {
  font-size: 24rpx;
  color: #555555;
}

.ck-type {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
}

.ck-type-normal {
  color: #5a8fc7;
  background: #eef6fc;
}

.ck-type-makeup {
  color: #a98d5b;
  background: #fdf5e6;
}

.actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 24rpx;
}

.act-btn {
  width: 100% !important;
}

.sheet-title {
  padding: 28rpx 32rpx 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}
