<view class="page safe-bottom" wx:if="{{goal}}">
  <view class="head-card">
    <view class="head-row">
      <view class="type-badge type-{{goal.type}}">{{goal.type === 'main' ? '主' : '子'}}</view>
      <text class="title">{{goal.name}}</text>
      <text class="status status-{{goal.status}}">{{statusZh}}</text>
    </view>
    <view class="meta-line">
      <text class="meta-item">{{goal.startDate}} → {{goal.endDate}}</text>
      <text wx:if="{{tagName}}" class="meta-tag">#{{tagName}}</text>
    </view>
    <view class="prog-row">
      <van-progress
        percentage="{{goal.progress || 0}}"
        stroke-width="12"
        color="linear-gradient(90deg, #b8e0ff 0%, #7ec8e3 100%)"
        inactive-color="#eef2f6"
        show-pivot="{{false}}"
      />
      <text class="prog-text">{{goal.progress || 0}}%</text>
    </view>
    <view wx:if="{{ruleText}}" class="rule-hint">{{ruleText}}</view>
  </view>

  <!-- 主要动作：打卡 / 补卡（子目标） -->
  <view wx:if="{{goal.type === 'sub'}}" class="action-card">
    <van-button
      type="primary"
      block
      round
      disabled="{{!canCheckIn}}"
      custom-class="primary-btn"
      bind:click="onCheckIn"
    >
      立即打卡
    </van-button>
    <text wx:if="{{!canCheckIn && checkReason}}" class="tip">{{checkReason}}</text>
    <view wx:if="{{makeupOptions.length}}" class="makeup-wrap">
      <van-button plain hairline size="small" round bind:click="toggleMakeup" icon="replay">
        补卡
      </van-button>
    </view>
  </view>

  <!-- 主目标：关联子目标 -->
  <view wx:if="{{goal.type === 'main'}}" class="section-card">
    <view class="section-head">
      <text class="section-title">关联子目标</text>
      <view wx:if="{{goal.status !== 'archived' && goal.status !== 'deleted'}}" class="section-action" bindtap="goRelink">
        <van-icon name="edit" size="26rpx" color="#5a8fc7" />
        <text>调整</text>
      </view>
    </view>
    <view wx:if="{{goal.subLinksDisplay && goal.subLinksDisplay.length}}">
      <view
        wx:for="{{goal.subLinksDisplay}}"
        wx:key="subGoalId"
        class="sub-row"
        data-id="{{item.subGoalId}}"
        bindtap="goSubDetail"
      >
        <text class="sub-name">{{item.subName}}</text>
        <view class="sub-right">
          <text class="sub-weight">{{item.weight}}%</text>
          <van-icon name="arrow" size="24rpx" color="#a0a7b0" />
        </view>
      </view>
    </view>
    <view wx:else class="empty-line">暂未关联子目标，主目标状态仅随日期变化。</view>
  </view>

  <!-- 描述 -->
  <view wx:if="{{goal.description}}" class="section-card">
    <view class="section-head">
      <text class="section-title">目标描述</text>
    </view>
    <text class="desc-text">{{goal.description}}</text>
  </view>

  <!-- 最近打卡记录（子目标） -->
  <view wx:if="{{goal.type === 'sub' && recentCheckIns.length}}" class="section-card">
    <view class="section-head">
      <text class="section-title">最近打卡</text>
      <text class="section-sub">仅展示最近 10 条</text>
    </view>
    <view wx:for="{{recentCheckIns}}" wx:key="ts" class="ck-row">
      <text class="ck-label">{{item.label}}</text>
      <text class="ck-type ck-type-{{item.type}}">{{item.type === 'makeup' ? '补卡' : '正常'}}</text>
    </view>
  </view>

  <!-- 次要操作：复盘 / 编辑 / 暂停 / 归档 / 删除 -->
  <view class="actions">
    <van-button plain hairline round custom-class="act-btn" icon="notes-o" bind:click="goReview">复盘</van-button>
    <van-button wx:if="{{goal.status !== 'deleted'}}" plain hairline round custom-class="act-btn" icon="edit" bind:click="goEdit">编辑</van-button>
    <van-button
      wx:if="{{goal.status === 'in_progress' || goal.status === 'not_started'}}"
      plain
      hairline
      round
      custom-class="act-btn"
      icon="pause-circle-o"
      bind:click="onPause"
    >
      暂停
    </van-button>
    <van-button
      wx:if="{{goal.status === 'paused'}}"
      plain
      hairline
      round
      custom-class="act-btn"
      icon="play-circle-o"
      bind:click="onResume"
    >
      恢复
    </van-button>
    <van-button
      wx:if="{{goal.status === 'completed' || goal.status === 'incomplete'}}"
      plain
      hairline
      round
      custom-class="act-btn"
      icon="records-o"
      bind:click="onArchive"
    >
      归档
    </van-button>
    <van-button
      wx:if="{{goal.status !== 'deleted' && goal.status !== 'archived'}}"
      plain
      hairline
      type="danger"
      round
      custom-class="act-btn"
      icon="delete-o"
      bind:click="onDelete"
    >
      删除
    </van-button>
  </view>

  <van-popup show="{{showMakeup}}" position="bottom" round closeable bind:close="onCloseMakeup">
    <view class="sheet-title">选择补卡周期</view>
    <van-cell-group>
      <van-cell
        wx:for="{{makeupOptions}}"
        wx:key="key"
        title="{{item.label}}"
        is-link
        data-mk="{{item.key}}"
        bind:click="onMakeup"
      />
    </van-cell-group>
  </van-popup>
</view>
