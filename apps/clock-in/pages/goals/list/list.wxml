<view class="page safe-bottom">
  <view class="topbar">
    <view class="top-entry" bindtap="goTags">
      <van-icon name="label-o" size="36rpx" color="#5a8fc7" />
      <text class="top-entry-text">标签管理</text>
    </view>
    <view class="top-actions">
      <view class="chip-hit" bindtap="toggleActiveOnly">
        <van-tag plain="{{!activeOnly}}" type="{{activeOnly ? 'primary' : 'default'}}" size="medium">
          {{activeOnly ? '仅进行中' : '显示全部'}}
        </van-tag>
      </view>
      <van-button type="primary" size="small" round bind:click="goAdd" icon="plus">新建</van-button>
    </view>
  </view>

  <van-loading wx:if="{{loading}}" type="spinner" vertical size="24px" class="load-block">加载中…</van-loading>

  <view wx:for="{{goals}}" wx:key="id" class="goal-card" data-gid="{{item.id}}" bindtap="goDetail">
    <view class="goal-head">
      <view class="goal-title-wrap">
        <view class="type-badge type-{{item.type}}">{{item.type === 'main' ? '主' : '子'}}</view>
        <text class="goal-title">{{item.name}}</text>
      </view>
      <text class="goal-status status-{{item.status}}">{{item.statusZh}}</text>
    </view>

    <view class="goal-meta">
      <text class="meta-date">至 {{item.endDate}}</text>
      <view wx:if="{{item.tagName}}" class="meta-tag-wrap">
        <van-tag plain type="primary" size="mini" custom-class="meta-tag">{{item.tagName}}</van-tag>
      </view>
    </view>

    <view class="goal-progress">
      <van-progress
        percentage="{{item.progress || 0}}"
        stroke-width="8"
        color="linear-gradient(90deg, #b8e0ff 0%, #7ec8e3 100%)"
        inactive-color="#eef2f6"
        show-pivot="{{false}}"
      />
      <text class="prog">{{item.progress || 0}}%</text>
    </view>

    <view wx:if="{{item.type === 'main' && item.subLinksDisplay.length}}" class="sub-chips">
      <text class="sub-label">关联子目标</text>
      <view class="sub-chip-row">
        <view wx:for="{{item.subLinksDisplay}}" wx:for-item="sub" wx:key="subGoalId" class="sub-chip">
          <text class="sub-chip-name">{{sub.subName}}</text>
          <text class="sub-chip-weight">{{sub.weight}}%</text>
        </view>
      </view>
    </view>
    <view wx:elif="{{item.type === 'main' && !item.subLinksDisplay.length}}" class="sub-empty">
      <text>暂未关联子目标</text>
    </view>
  </view>

  <van-empty wx:if="{{!loading && !goals.length}}" description="暂无目标，点击「新建」开始吧" />
</view>
