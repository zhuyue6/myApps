.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.top-entry {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top-entry-text {
  font-size: 28rpx;
  color: #5a8fc7;
  font-weight: 500;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chip-hit {
  display: inline-flex;
}

.load-block {
  display: block;
  text-align: center;
  padding: 48rpx 0;
}

.goal-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.06);
}

.goal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.goal-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.type-badge {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  color: #ffffff;
  flex-shrink: 0;
}

.type-main {
  background: #7ec8e3;
}

.type-sub {
  background: #b9d5e7;
}

.goal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goal-status {
  font-size: 24rpx;
  color: #888888;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-in_progress {
  color: #5a8fc7;
}

.status-completed {
  color: #5cb67f;
}

.status-incomplete {
  color: #d98e8e;
}

.status-paused {
  color: #a98d5b;
}

.goal-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.meta-date {
  font-size: 24rpx;
  color: #888888;
}

.meta-tag {
  font-size: 22rpx !important;
}

.goal-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.goal-progress .van-progress {
  flex: 1;
}

.prog {
  font-size: 24rpx;
  color: #888888;
  min-width: 80rpx;
  text-align: right;
}

.sub-chips {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #eef2f6;
}

.sub-label {
  display: block;
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.sub-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sub-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  background: #f0f7ff;
  color: #5a8fc7;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  max-width: 100%;
}

.sub-chip-name {
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub-chip-weight {
  color: #7ea4c9;
}

.sub-empty {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #b4bac1;
}
