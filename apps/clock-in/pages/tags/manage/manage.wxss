.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 18rpx 24rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}

.sec-title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 0 8rpx 12rpx;
}

.sec-title text:first-child {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.sec-title-tip {
  font-size: 22rpx;
  color: #a0a7b0;
}

.tag-list {
  padding: 8rpx 24rpx;
}

.tag-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f5f9;
}

.tag-row:last-child {
  border-bottom: none;
}

.tag-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.tag-chip {
  font-size: 24rpx !important;
}

.tag-sub {
  font-size: 22rpx;
  color: #a0a7b0;
}

.tag-actions {
  display: flex;
  gap: 8rpx;
}

.tag-empty {
  padding: 24rpx 0;
  text-align: center;
  color: #a0a7b0;
  font-size: 24rpx;
}

.edit-sheet {
  padding: 36rpx 32rpx;
}

.edit-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.half-btn {
  flex: 1 !important;
}
