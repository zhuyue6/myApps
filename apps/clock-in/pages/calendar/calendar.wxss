.page {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.today-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 16rpx;
}

.selected-card {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 16rpx;
}

.selected-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.selected-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.selected-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.selected-tag.done {
  color: #ffffff;
  background: #7ed0a0;
}

.selected-tag.checked {
  color: #5a8fc7;
  background: #dcebfa;
}

.selected-tag.planned {
  color: #6a8eb0;
  background: #eef6fc;
}

.selected-tag.empty {
  color: #a0a7b0;
  background: #f3f5f9;
}

.selected-body {
  display: flex;
  gap: 24rpx;
}

.stat-col {
  flex: 1;
  background: #f6f9fd;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.stat-val {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #5a8fc7;
}

.stat-lbl {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #888888;
}
