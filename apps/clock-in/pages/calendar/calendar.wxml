<view class="page safe-bottom">
  <goal-calendar-board
    year="{{year}}"
    month="{{month}}"
    day-stats="{{dayStats}}"
    selected-date="{{selectedDate}}"
    bind:yearchange="onYearChange"
    bind:monthchange="onMonthChange"
    bind:daypick="onDayPick"
  />

  <view class="today-wrap">
    <van-button size="small" plain round bind:click="goToday">回到今天</van-button>
  </view>

  <view wx:if="{{selectedInfo}}" class="selected-card">
    <view class="selected-head">
      <text class="selected-date">{{selectedInfo.ymd}}</text>
      <text wx:if="{{selectedInfo.planned > 0 && selectedInfo.checked >= selectedInfo.planned}}" class="selected-tag done">已完成</text>
      <text wx:elif="{{selectedInfo.checked > 0}}" class="selected-tag checked">打卡 {{selectedInfo.checked}}</text>
      <text wx:elif="{{selectedInfo.planned > 0}}" class="selected-tag planned">计划 {{selectedInfo.planned}}</text>
      <text wx:else class="selected-tag empty">无记录</text>
    </view>
    <view class="selected-body">
      <view class="stat-col">
        <text class="stat-val">{{selectedInfo.planned}}</text>
        <text class="stat-lbl">计划次数</text>
      </view>
      <view class="stat-col">
        <text class="stat-val">{{selectedInfo.checked}}</text>
        <text class="stat-lbl">已打卡</text>
      </view>
    </view>
  </view>

  <van-notice-bar
    color="#888888"
    background="#f6f8fb"
    left-icon="info-o"
    text="日期上「计划 N」为当日应打卡次数，「打卡 M」为已打卡次数，完成时自动标记「已完成」。"
  />
</view>
