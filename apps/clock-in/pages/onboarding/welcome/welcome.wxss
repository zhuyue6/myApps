.page {
  padding: 48rpx 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.hero {
  margin-bottom: 48rpx;
}
.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  line-height: 1.5;
}
.sub {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}
.full {
  width: 100%;
}
