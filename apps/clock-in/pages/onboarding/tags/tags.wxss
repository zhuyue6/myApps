.page {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin: 24rpx 0 32rpx;
}

.chip-hit {
  display: inline-flex;
}

.card {
  margin-bottom: 32rpx;
}

.row-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.half {
  flex: 1;
  width: auto !important;
}
