.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f3ecff 0%, #faf8fc 45%, #fafafa 100%);
  padding: 32rpx 28rpx 200rpx;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 28rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #444444;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.55;
}

.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 4rpx 14rpx rgba(122, 82, 176, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #7a52b0;
  line-height: 1;
}

.stat-label {
  font-size: 22rpx;
  color: #888888;
}

.play-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #c4a0e8 0%, #9b70cc 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(122, 82, 176, 0.35);
}

.play-btn::after {
  border: none;
}

.play-btn-hover {
  opacity: 0.9;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 10rpx;
  display: block;
}

.section-hint {
  font-size: 22rpx;
  color: #aaaaaa;
  line-height: 1.45;
  display: block;
  margin-bottom: 20rpx;
}

.color-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.color-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.color-card.locked {
  opacity: 0.55;
}

.color-dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.color-name {
  font-size: 22rpx;
  color: #555555;
  text-align: center;
}

.badge {
  font-size: 18rpx;
  color: #aaaaaa;
}

.badge.ok {
  color: #5a9e6a;
  font-weight: 600;
}

.card-tips {
  padding: 24rpx 22rpx;
  background: rgba(196, 160, 232, 0.12);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.tips-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 12rpx;
}

.tips-line {
  display: block;
  font-size: 24rpx;
  color: #777777;
  line-height: 1.55;
  margin-bottom: 8rpx;
}

.footer-stats {
  padding: 20rpx;
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}
